@startuml Pricing Library Architecture
!theme plain
skinparam backgroundColor #FFFFFF

title Pricing Library - Visitor Pattern for Valuation

package "Valuation Nodes" {
    
    abstract class "ValuationNode" {
        + {abstract} accept(visitor)
    }
    
    package "Asset Nodes" {
        class "SpotNode" {
            - spot: float
            + accept(visitor)
        }
        
        class "VolatilityNode" {
            - volatility: float
            + accept(visitor)
        }
        
        class "RateNode" {
            - rate: float
            + accept(visitor)
        }
    }
    
    package "Option Nodes" {
        class "EuropeanCallNode" {
            - spot: float
            - strike: float
            - maturity: float
            - rate: float
            - volatility: float
            + accept(visitor)
        }
        
        class "EuropeanPutNode" {
            - spot: float
            - strike: float
            - maturity: float
            - rate: float
            - volatility: float
            + accept(visitor)
        }
    }
    
    package "Greek Nodes" {
        class "DeltaNode" {
            - option: OptionNode
            + accept(visitor)
        }
        
        class "GammaNode" {
            - option: OptionNode
            + accept(visitor)
        }
        
        class "VegaNode" {
            - option: OptionNode
            + accept(visitor)
        }
    }
}

package "Visitors" {
    
    interface "ValuationVisitor" {
        + visit_spot(node)
        + visit_european_call(node)
        + visit_delta(node)
        + ...
    }
    
    class "PriceCalculatorVisitor" {
        + visit_spot(node): float
        + visit_european_call(node): float
        + visit_delta(node): float
        - black_scholes(params): float
    }
    
    class "ScenarioVisitor" {
        - shifts: list[float]
        + visit_spot(node): dict
        + visit_european_call(node): dict
        + visit_delta(node): dict
    }
    
    class "DescriptionVisitor" {
        + visit_spot(node): str
        + visit_european_call(node): str
        + visit_delta(node): str
    }
}

ValuationNode <|-- SpotNode
ValuationNode <|-- VolatilityNode
ValuationNode <|-- RateNode
ValuationNode <|-- EuropeanCallNode
ValuationNode <|-- EuropeanPutNode
ValuationNode <|-- DeltaNode
ValuationNode <|-- GammaNode
ValuationNode <|-- VegaNode

ValuationVisitor <|.. PriceCalculatorVisitor
ValuationVisitor <|.. ScenarioVisitor
ValuationVisitor <|.. DescriptionVisitor

ValuationNode .right.> ValuationVisitor : accepts

note right of ValuationNode
  **Node Responsibilities:**
  - Hold valuation parameters
  - Accept visitors
  - No calculation logic
end note

note left of ValuationVisitor
  **Visitor Responsibilities:**
  - Implement calculations
  - Handle all node types
  - Return results
end note

note bottom of PriceCalculatorVisitor
  **Black-Scholes Implementation:**
  - Closed-form solution
  - Analytical Greeks
  - Fast computation
end note

note bottom of ScenarioVisitor
  **Scenario Analysis:**
  - Spot shifts
  - Vol shifts
  - Rate shifts
  - Stress testing
end note

@enduml
