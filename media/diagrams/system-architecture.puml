@startuml System Architecture
!theme plain
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle

title Trading Platform - System Architecture

package "Trading Platform" {
    
    package "Strategy Mediator" {
        component [Strategy\nComponents] as StratComp
        component [Order\nExecution] as OrderExec
        component [Market Data\nHandler] as MarketData
    }
    
    package "Reporting Mediator" {
        component [Risk\nCalculator] as Risk
        component [Portfolio\nAggregator] as Portfolio
        component [Performance\nAnalytics] as Perf
        component [Strategy\nRegistry] as Registry
    }
    
    package "Dashboard Mediator" {
        component [UI\nComponents] as UIComp
        component [IPC\nBridge] as IPC
        component [Event\nHandlers] as Events
    }
    
    package "Desktop UI" {
        component [React\nFrontend] as React
        component [Electron\nMain] as Electron
    }
}

package "Message Infrastructure" {
    database "Kafka" as Kafka
    database "RabbitMQ" as RabbitMQ
}

package "Data Layer" {
    database "PostgreSQL" as Postgres
    database "TimescaleDB" as Timescale
}

' Strategy -> Reporting flows
StratComp -down-> Kafka : Strategy\nRegistration
StratComp -down-> Kafka : Heartbeats
StratComp -down-> Kafka : Trades
OrderExec -down-> Kafka : Fills

' Reporting -> Dashboard flows
Risk -down-> RabbitMQ : Risk\nMetrics
Portfolio -down-> RabbitMQ : Portfolio\nUpdates
Registry -down-> RabbitMQ : Strategy\nStatus

' Kafka -> Reporting
Kafka -down-> Registry : Subscribe
Kafka -down-> Portfolio : Subscribe
Kafka -down-> Perf : Subscribe

' RabbitMQ -> Dashboard
RabbitMQ -down-> UIComp : Subscribe
RabbitMQ -down-> Events : Subscribe

' Dashboard -> UI
UIComp -right-> IPC : JSON/IPC
IPC -right-> Electron : stdin/stdout
Electron -down-> React : Events

' React -> Dashboard
React -up-> Electron : Commands
Electron -up-> IPC : stdin/stdout
IPC -left-> Events : Process

' Data persistence
Portfolio -down-> Postgres : State
Perf -down-> Timescale : Metrics
MarketData -down-> Timescale : Tick Data

note right of Kafka
  High-throughput
  Persistent log
  Replay capability
end note

note right of RabbitMQ
  Low-latency
  Flexible routing
  Priority queues
end note

note bottom of Postgres
  ACID compliance
  Relational data
  Configuration
end note

note bottom of Timescale
  Time-series optimized
  Compression
  Fast queries
end note

@enduml
